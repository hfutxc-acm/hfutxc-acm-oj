# ==========================================
# 操作系统与 IDE 相关 (OS & IDE)
# ==========================================
.DS_Store
Thumbs.db
# 忽略 JetBrains 全家桶 (PyCharm/CLion/WebStorm) 的配置目录
.idea/
# 忽略 VS Code 的配置目录 (备用)
.vscode/

# ==========================================
# 前端部分 (Frontend - Vue 3 / Vite)
# ==========================================
# 依赖包 (绝对不能传 Git，体积极大)
frontend/node_modules/
frontend/.pnpm-store/
# 构建输出的生产环境代码
frontend/dist/
frontend/dist-ssr/
# 本地环境变量
frontend/.env.local
frontend/.eslintcache

# ==========================================
# 后端部分 (Backend - Python / FastAPI)
# ==========================================
# Python 编译的字节码缓存
__pycache__/
*.py[cod]
*$py.class
# Python 虚拟环境目录
backend/venv/
backend/env/
backend/.venv/
# 后端敏感的环境变量 (如密钥等)
backend/.env
# 日志文件
*.log

# ------------------------------------------
# 数据库 (Database)
# ------------------------------------------
# 忽略 SQLite 数据库文件 (不要把本地测试数据传到云端)
*.db
*.sqlite3

# ==========================================
# 评测机与 C++ 沙箱 (Judger & C++)
# ==========================================
# CLion 的默认构建目录
cmake-build-*/
build/
# 编译产生的对象文件和可执行文件
*.o
*.out
*.exe
*.so
*.dylib
*.a

# ==========================================
# OJ 业务专属目录 (OJ Specific)
# ==========================================
# 用户的临时提交代码文件 (评测完就该销毁或只留本地)
submissions/
temp_code/
# 题目的测试样例数据输入输出 (Test cases)
# 这些文件可能非常大，建议后续放在服务器指定目录或单独用云存储
data/
testcases/